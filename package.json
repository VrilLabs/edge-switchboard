{
  "name": "@kronos/edge-switchboard",
  "version": "0.1.0",
  "description": "Edge proxy switchboard — hot-swap provider routing, weighted load balancing, health checks, sticky sessions, and key carousel integration for Cloudflare Workers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.test.json && mocha dist/**/*.test.js --timeout 5000",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "edge",
    "proxy",
    "switchboard",
    "cloudflare-workers",
    "hot-swap",
    "load-balancer",
    "routing",
    "durable-objects"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VrilLabs/kronos-timewarp",
    "directory": "packages/edge-switchboard"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "mocha": "^10.7.3",
    "@types/mocha": "^10.0.9"
  }
}
